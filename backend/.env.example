# ===============================================================================
# MY CLOSET BACKEND - ENVIRONMENT CONFIGURATION
# Phase 4: VLM Integration & Image Preprocessing
# ===============================================================================

# --- DATABASE & AUTHENTICATION ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# --- VLM PROVIDER CONFIGURATION ---
# Phase 4: Select which VLM provider to use
# Options: "mock" (for testing) or "llava" (for real recommendations)
# Default: "mock"
VLM_PROVIDER=mock

# Enable/disable VLM functionality entirely
# If false, system will use rule-based recommendations
# Default: true
ENABLE_VLM=true

# ===============================================================================
# LLAVA VLM CONFIGURATION
# ===============================================================================

# LLaVA API Endpoint
# For local Ollama (recommended for development):
#   LLAVA_API_ENDPOINT=http://localhost:11434/v1/chat/completions
#
# For external cloud services (e.g., Replicate):
#   LLAVA_API_ENDPOINT=https://api.replicate.com/v1/predictions
#
# Default: http://localhost:11434/v1/chat/completions
LLAVA_API_ENDPOINT=http://localhost:11434/v1/chat/completions

# LLaVA Model Name/ID
# For local Ollama:
#   LLAVA_MODEL_NAME=llava:latest
#   or specific version: llava:7b, llava:13b
#
# For Replicate:
#   LLAVA_MODEL_NAME=replicate/llava-13b
#
# Default: llava:latest
LLAVA_MODEL_NAME=llava:latest

# API Key for external services (optional)
# Only needed if using a cloud VLM service that requires authentication
# Leave empty for local Ollama
# Default: (empty)
LLAVA_API_KEY=

# Request timeout in seconds
# Adjust based on your hardware:
# - Local CPU: 300-600 seconds (5-10 minutes)
# - Local GPU: 60-120 seconds (1-2 minutes)
# - Cloud API: 30-60 seconds
# Default: 300
LLAVA_TIMEOUT=300

# Maximum tokens in LLaVA response
# Outfit recommendations typically need 300-500 tokens
# Travel outfits need 800-1024 tokens
# Default: 1024
LLAVA_MAX_TOKENS=1024

# LLaVA response temperature (creativity vs determinism)
# 0.0 = deterministic (same outfit every time)
# 0.5 = balanced (some variety, but consistent)
# 1.0+ = creative (very different outfits each time)
# Recommended for outfit recommendations: 0.2-0.4
# Default: 0.3
LLAVA_TEMPERATURE=0.3

# ===============================================================================
# IMAGE PREPROCESSING CONFIGURATION
# ===============================================================================

# Maximum number of images to send to VLM per request
# VLMs have memory limitations - more images = slower processing + higher risk of OOM
# Recommended values:
# - Local CPU: 2-4 images
# - Local GPU: 4-8 images
# - Cloud API: Varies by provider (typically 4-6)
# Default: 6
IMAGE_PREPROCESSING_MAX_IMAGES=6

# Maximum image file size in MB
# Larger images = slower preprocessing + higher memory usage
# Recommended: 3-5 MB for balance of quality and speed
# Default: 5
IMAGE_PREPROCESSING_MAX_SIZE_MB=5

# ===============================================================================
# HOW TO CONFIGURE FOR DIFFERENT SCENARIOS
# ===============================================================================

# SCENARIO 1: LOCAL OLLAMA (Recommended for Development)
# ─────────────────────────────────────────────────────
# Steps:
# 1. Install Ollama: https://ollama.ai
# 2. Pull LLaVA: ollama pull llava
# 3. Start Ollama: ollama serve
# 4. Configure:
#
# VLM_PROVIDER=llava
# LLAVA_API_ENDPOINT=http://localhost:11434/v1/chat/completions
# LLAVA_MODEL_NAME=llava:latest
# LLAVA_TIMEOUT=300
# LLAVA_API_KEY=
#
# Then restart the backend and test endpoints.


# SCENARIO 2: MOCK MODE (For Testing Without VLM)
# ─────────────────────────────────────────────────
# Use this when:
# - Developing frontend UI
# - Testing without VLM setup
# - Debugging recommendation flow
#
# VLM_PROVIDER=mock
# ENABLE_VLM=true
#
# The system will use MockVLMService which returns hardcoded recommendations.
# Useful for testing without real VLM latency.


# SCENARIO 3: EXTERNAL API (e.g., Replicate)
# ─────────────────────────────────────────────
# Steps:
# 1. Create account at https://replicate.com
# 2. Get API token from dashboard
# 3. Configure:
#
# VLM_PROVIDER=llava
# LLAVA_API_ENDPOINT=https://api.replicate.com/v1/predictions
# LLAVA_MODEL_NAME=replicate/llava-13b
# LLAVA_API_KEY=your_replicate_token_here
# LLAVA_TIMEOUT=120
#
# Note: Cloud services may have rate limiting and pricing.


# SCENARIO 4: RULE-BASED ONLY (No VLM)
# ──────────────────────────────────────
# Use this if VLM is not available or you want deterministic recommendations:
#
# ENABLE_VLM=false
#
# The system will use rule-based outfit selection based on:
# - Temperature matching
# - Weather conditions
# - Item usage frequency
# - Layer coherence


# ===============================================================================
# TROUBLESHOOTING
# ===============================================================================

# Problem: "Failed to connect to LLaVA"
# Solution: Ensure Ollama is running: ollama serve

# Problem: "Out of memory (OOM)"
# Solution: Reduce IMAGE_PREPROCESSING_MAX_IMAGES or LLAVA_TIMEOUT

# Problem: "LLaVA returning invalid JSON"
# Solution: Check LLAVA_TIMEOUT is high enough for model to process

# Problem: "Image processing failing"
# Solution: Check IMAGE_PREPROCESSING_MAX_SIZE_MB is not too restrictive

